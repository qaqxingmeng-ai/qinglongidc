# Backend example config.
# Real local secrets should live outside the repo, for example:
#   ~/.config/serverai/backend.env
# The server loads external env first, then falls back to project-local .env.local / .env.

# Server
PORT=8080
# Trust forwarding headers only from these proxy IPs / CIDRs.
# Default is loopback for same-host Next.js -> Go deployments.
# Add your internal proxy network here if BFF and backend run on different hosts/containers.
TRUSTED_PROXIES=127.0.0.1,::1

# Database
DATABASE_URL=postgres://serverai:change-me@localhost:5432/serverai?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production

# Internal API Key (BFF -> Go backend)
INTERNAL_API_KEY=your-internal-api-key-here

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_SELECTOR_MODEL=
OPENAI_FALLBACK_MODEL=gpt-4o-mini
OPENAI_REASONING_EFFORT=high
OPENAI_SELECTOR_REASONING_EFFORT=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# WAF
WAF_ENABLED=true
WAF_IP_WHITELIST=
WAF_IP_BLACKLIST=
WAF_RATE_LIMIT_PER_SEC=60
WAF_MAX_BODY_BYTES=26214400

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cookie
# proxy mode (same-origin via Next.js /api): COOKIE_DOMAIN can stay empty
# direct split mode (e.g. app.example.com + api.example.com):
# set COOKIE_DOMAIN=.example.com and COOKIE_SECURE=true (HTTPS required)
COOKIE_SECURE=false
COOKIE_DOMAIN=
