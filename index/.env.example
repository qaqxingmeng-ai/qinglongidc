# AI Server Platform - Next.js BFF Configuration
# Real local server-only values should live outside the repo, for example:
#   ~/.config/serverai/frontend.env
# Dev/build scripts load that file before falling back to project-local env files.
# Next.js only serves as BFF proxy, NO direct database access.

# API mode:
# - proxy (default): browser -> Next.js /api -> Go backend (recommended)
# - direct: browser -> Go backend directly (true split deployment)
NEXT_PUBLIC_API_MODE=proxy

# Direct mode only: public backend base URL (e.g. https://api.example.com)
# Keep empty when using proxy mode.
NEXT_PUBLIC_API_BASE_URL=

# Go Backend URL (server-side only, never exposed to browser)
GO_BACKEND_URL=http://127.0.0.1:8080

# Internal API Key (must match backend INTERNAL_API_KEY, server-side only)
API_INTERNAL_KEY=your-internal-api-key-here

# Public settings (exposed to browser)
NEXT_PUBLIC_APP_NAME="AI Server Platform"
NEXT_PUBLIC_APP_URL=http://localhost:3000
